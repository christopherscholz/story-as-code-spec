@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix sac:   <https://story-as-code.dev/ontology#> .
@prefix sacsh: <https://story-as-code.dev/shapes/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

sacsh:DerivationLayerShape
    a sh:NodeShape ;
    rdfs:comment "Container for derived outputs — rendered text linked to world and narrative elements." ;
    sh:targetClass sac:DerivationLayer ;
    sh:property [
        sh:path sac:hasRendering ;
        sh:description "Rendered text outputs." ;
        sh:class sac:Rendering ;
    ] .
