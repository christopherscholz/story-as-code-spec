@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix sac:   <https://story-as-code.dev/ontology#> .
@prefix sacsh: <https://story-as-code.dev/shapes/> .
@prefix sacex: <https://story-as-code.dev/expr/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

sacsh:SelectorExpressionShape a sh:NodeShape ;
    rdfs:comment "A tuple identifying a story element by type and item." ;
    sh:targetClass sacex:SelectorExpression ;
    sh:property [
        sh:path sacex:selectorType ;
        sh:description "Element kind (e.g. node, edge, frame, tag, time, beat, lens, format, device, thread, variant)." ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sacex:selectorItem ;
        sh:description "ID of the element being selected." ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .
