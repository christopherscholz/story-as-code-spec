@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix sac:   <https://story-as-code.dev/ontology#> .
@prefix sacsh: <https://story-as-code.dev/shapes/> .
@prefix sacex: <https://story-as-code.dev/expr/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

# --- Union expression shape (recursive, used as a referenced shape) ---

sacsh:ExpressionShape a sh:NodeShape ;
    rdfs:comment "A boolean expression over story elements. Either a direct IRI reference (leaf), or a boolean/set operator combining expressions." ;
    sh:or (
        [ sh:nodeKind sh:IRI ]
        sacsh:AndExpressionShape
        sacsh:OrExpressionShape
        sacsh:NotExpressionShape
        sacsh:InExpressionShape
        sacsh:RangeExpressionShape
    ) .

# --- Logical combinators ---

sacsh:AndExpressionShape a sh:NodeShape ;
    sh:property [
        sh:path sacex:andOperands ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .

sacsh:OrExpressionShape a sh:NodeShape ;
    sh:property [
        sh:path sacex:orOperands ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .

sacsh:NotExpressionShape a sh:NodeShape ;
    sh:property [
        sh:path sacex:notOperand ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .

# --- Set / range expressions ---

sacsh:InExpressionShape a sh:NodeShape ;
    rdfs:comment "Matches if the element is one of the listed values." ;
    sh:property [
        sh:path sacex:inItems ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
    ] .

sacsh:RangeExpressionShape a sh:NodeShape ;
    rdfs:comment "Matches all elements between from and to (inclusive). Use null for open boundaries." ;
    sh:property [
        sh:path sacex:rangeFrom ;
        sh:description "Start of the range (inclusive). Null for open lower boundary." ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
    ] ;
    sh:property [
        sh:path sacex:rangeTo ;
        sh:description "End of the range (inclusive). Null for open upper boundary." ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
    ] .
