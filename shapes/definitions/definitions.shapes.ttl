@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix sac:   <https://story-as-code.dev/ontology#> .
@prefix sacsh: <https://story-as-code.dev/shapes/> .
@prefix sacex: <https://story-as-code.dev/expr/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

sacsh:DefinitionsLayerShape
    a sh:NodeShape ;
    sh:targetClass sac:DefinitionsLayer ;
    sh:property [
        sh:path sac:hasTags ;
        sh:node sacsh:TagShape ;
    ] ;
    sh:property [
        sh:path sac:hasTypes ;
        sh:node sacsh:TypeDefinitionShape ;
    ] .
