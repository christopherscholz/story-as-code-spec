@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix sac:   <https://story-as-code.dev/ontology#> .
@prefix sacsh: <https://story-as-code.dev/shapes/> .
@prefix sacex: <https://story-as-code.dev/expr/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

sacsh:NarrativeLayerShape
    a sh:NodeShape ;
    rdfs:comment "The narrative layer — how the world is told." ;
    sh:targetClass sac:NarrativeLayer ;
    sh:property [
        sh:path sac:hasLens ;
        sh:description "Narrative perspectives." ;
        sh:class sac:Lens ;
    ] ;
    sh:property [
        sh:path sac:hasBeat ;
        sh:description "Hierarchical narrative building blocks." ;
        sh:class sac:Beat ;
    ] ;
    sh:property [
        sh:path sac:hasDevice ;
        sh:description "Rhetorical techniques connecting beats (foreshadowing, red herrings, etc.)." ;
        sh:class sac:Device ;
    ] ;
    sh:property [
        sh:path sac:hasThread ;
        sh:description "Thematic threads and motifs connecting beats across storylines." ;
        sh:class sac:Thread ;
    ] ;
    sh:property [
        sh:path sac:hasFormat ;
        sh:description "Output format definitions." ;
        sh:class sac:Format ;
    ] ;
    sh:property [
        sh:path sac:hasVariant ;
        sh:description "Parallel world version metadata." ;
        sh:class sac:VariantMeta ;
    ] .
