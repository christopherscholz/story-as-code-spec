@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix sac:   <https://story-as-code.dev/ontology#> .
@prefix sacsh: <https://story-as-code.dev/shapes/> .
@prefix sacex: <https://story-as-code.dev/expr/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

sacsh:DeviceShape
    a sh:NodeShape ;
    rdfs:comment "A narrative device — a rhetorical technique connecting beats." ;
    sh:targetClass sac:Device ;
    sh:property [
        sh:path sac:entityName ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:deviceType ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:setupBeats ;
        sh:description "Beat IDs where the device is planted." ;
        sh:nodeKind sh:IRI ;
        sh:class sac:Beat ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path sac:description ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:payoffBeats ;
        sh:description "Beat IDs where it resolves." ;
        sh:nodeKind sh:IRI ;
        sh:class sac:Beat ;
    ] ;
    sh:property [
        sh:path sac:hasTag ;
        sh:nodeKind sh:IRI ;
        sh:class sac:Tag ;
    ] .
