@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix sac:   <https://story-as-code.dev/ontology#> .
@prefix sacsh: <https://story-as-code.dev/shapes/> .
@prefix sacex: <https://story-as-code.dev/expr/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

sacsh:BeatShape
    a sh:NodeShape ;
    sh:targetClass sac:Beat ;
    sh:property [
        sh:path sac:entityName ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:description ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:parent ;
        sh:nodeKind sh:IRI ;
        sh:node sacsh:BeatShape ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:referencesNode ;
        sh:nodeKind sh:IRI ;
        sh:node sacsh:NodeShape ;
    ] ;
    sh:property [
        sh:path sac:referencesEdge ;
        sh:nodeKind sh:IRI ;
        sh:node sacsh:EdgeShape ;
    ] ;
    sh:property [
        sh:path sac:function ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:hasReveal ;
        sh:node sacsh:RevealShape ;
    ] ;
    sh:property [
        sh:path sac:tension ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
    ] ;
    sh:property [
        sh:path sac:emotionalTarget ;
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
        sh:minInclusive -1.0 ;
        sh:maxInclusive 1.0 ;
    ] ;
    sh:property [
        sh:path sac:hasTransition ;
        sh:maxCount 1 ;
        sh:node sacsh:TransitionShape ;
    ] .

sacsh:RevealShape
    a sh:NodeShape ;
    sh:property [
        sh:path sac:revealTarget ;
        sh:nodeKind sh:IRI ;
        sh:or ( [ sh:class sac:Node ] [ sh:class sac:Edge ] ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:degree ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] .

sacsh:TransitionShape
    a sh:NodeShape ;
    sh:property [
        sh:path sac:transitionType ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:toBeat ;
        sh:nodeKind sh:IRI ;
        sh:node sacsh:BeatShape ;
        sh:maxCount 1 ;
    ] .
