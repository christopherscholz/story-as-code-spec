@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix sac:   <https://story-as-code.dev/ontology#> .
@prefix sacsh: <https://story-as-code.dev/shapes/> .
@prefix sacex: <https://story-as-code.dev/expr/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

sacsh:FormatShape
    a sh:NodeShape ;
    sh:targetClass sac:Format ;
    sh:property [
        sh:path sac:entityName ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:formatType ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:structure ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:node sacsh:StructureShape ;
    ] ;
    sh:property [
        sh:path sac:formatSettings ;
        sh:datatype rdf:JSON ;
        sh:maxCount 1 ;
    ] .

sacsh:StructureShape
    a sh:NodeShape ;
    sh:property [
        sh:path sac:structureType ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:constraints ;
        sh:datatype rdf:JSON ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:children ;
        sh:maxCount 1 ;
        sh:node sacsh:StructureShape ;
    ] .
