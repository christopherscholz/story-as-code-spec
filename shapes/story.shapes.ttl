@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix sac:   <https://story-as-code.dev/ontology#> .
@prefix sacsh: <https://story-as-code.dev/shapes/> .
@prefix sacex: <https://story-as-code.dev/expr/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

sacsh:StoryShape
    a sh:NodeShape ;
    rdfs:comment "Root document of a Story as Code project." ;
    sh:targetClass sac:Story ;
    sh:property [
        sh:path sac:specVersion ;
        sh:description "Spec version this story conforms to." ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:entityName ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:world ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:nodeKind sh:IRI ]
            [ sh:node sacsh:WorldLayerShape ]
        ) ;
    ] ;
    sh:property [
        sh:path sac:settings ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:definitions ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:narrative ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:derivation ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:nodeKind sh:IRI ]
            [ sh:node sacsh:DerivationLayerShape ]
        ) ;
    ] .
