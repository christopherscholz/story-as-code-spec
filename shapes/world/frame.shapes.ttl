@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix sac:   <https://story-as-code.dev/ontology#> .
@prefix sacsh: <https://story-as-code.dev/shapes/> .
@prefix sacex: <https://story-as-code.dev/expr/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

sacsh:FrameShape
    a sh:NodeShape ;
    rdfs:comment "An alternative timeline or branch. Frames form a graph via parent references and relations." ;
    sh:targetClass sac:Frame ;
    sh:property [
        sh:path sac:entityName ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:description ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:parent ;
        sh:description "Frame this one branched from." ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:branchesAt ;
        sh:description "Time point where this frame diverges from parent." ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:hasRelation ;
        sh:node sacsh:FrameRelationShape ;
    ] ;
    sh:property [
        sh:path sac:hasTag ;
        sh:nodeKind sh:IRI ;
    ] ;
    sh:property [
        sh:path sac:properties ;
        sh:description "Additional metadata as key-value pairs." ;
        sh:datatype rdf:JSON ;
        sh:maxCount 1 ;
    ] .

sacsh:FrameRelationShape
    a sh:NodeShape ;
    sh:property [
        sh:path sac:target ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:relationType ;
        sh:description "How this frame relates to another — e.g. branching off at a divergence point, merging back, or looping." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:at ;
        sh:description "Time point at which the relation occurs." ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:description ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] .
