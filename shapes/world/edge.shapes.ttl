@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix sac:   <https://story-as-code.dev/ontology#> .
@prefix sacsh: <https://story-as-code.dev/shapes/> .
@prefix sacex: <https://story-as-code.dev/expr/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

sacsh:EdgeShape
    a sh:NodeShape ;
    rdfs:comment "A relationship between two nodes that persists over time." ;
    sh:targetClass sac:Edge ;
    sh:property [
        sh:path sac:edgeType ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:entityName ;
        sh:description "Verb describing the relationship." ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:source ;
        sh:nodeKind sh:IRI ;
        sh:node sacsh:NodeShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:target ;
        sh:nodeKind sh:IRI ;
        sh:node sacsh:NodeShape ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:description ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:directed ;
        sh:description "Whether the edge is directed (source → target). Default true." ;
        sh:datatype xsd:boolean ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:scope ;
        sh:description "Temporal scope of this edge. Omit for edges that always hold. Valid selectors: time_system, time, frame." ;
        sh:maxCount 1 ;
        sh:node sacsh:ExpressionShape ;
    ] .
