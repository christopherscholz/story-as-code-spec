@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix sac:   <https://story-as-code.dev/ontology#> .
@prefix sacsh: <https://story-as-code.dev/shapes/> .
@prefix sacex: <https://story-as-code.dev/expr/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

sacsh:TimeSystemShape
    a sh:NodeShape ;
    rdfs:comment "How time works in this world — its structure and calendar." ;
    sh:targetClass sac:TimeSystem ;
    sh:property [
        sh:path sac:entityName ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:timeSystemType ;
        sh:description "LINEAR — time points have a natural order and sort lexicographically. ABSTRACT — time points are unordered labels; sequence is defined through the graph." ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:calendar ;
        sh:description "Calendar structure." ;
        sh:datatype rdf:JSON ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path sac:properties ;
        sh:description "Additional time properties." ;
        sh:datatype rdf:JSON ;
        sh:maxCount 1 ;
    ] .
