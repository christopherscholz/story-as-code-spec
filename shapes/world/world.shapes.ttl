@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix sac:   <https://story-as-code.dev/ontology#> .
@prefix sacsh: <https://story-as-code.dev/shapes/> .
@prefix sacex: <https://story-as-code.dev/expr/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

sacsh:WorldLayerShape
    a sh:NodeShape ;
    rdfs:comment "The world graph — ground truth of the story universe." ;
    sh:targetClass sac:WorldLayer ;
    sh:property [
        sh:path sac:timeSystem ;
        sh:maxCount 1 ;
        sh:node sacsh:TimeSystemShape ;
    ] ;
    sh:property [
        sh:path sac:hasNode ;
        sh:class sac:Node ;
    ] ;
    sh:property [
        sh:path sac:hasEdge ;
        sh:class sac:Edge ;
    ] ;
    sh:property [
        sh:path sac:hasFrame ;
        sh:description "Alternative timelines and branches." ;
        sh:class sac:Frame ;
    ] ;
    sh:property [
        sh:path sac:hasConstraint ;
        sh:class sac:Constraint ;
    ] .
