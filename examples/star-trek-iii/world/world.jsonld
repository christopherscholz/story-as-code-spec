  "constraints": [
    {
      "type": "Constraint",
      "id": "genesis-instability",
      "name": "Genesis Planet is unstable",
      "description": "The Genesis Planet ages and disintegrates rapidly due to David's use of protomatter. All events on the planet surface are under increasing time pressure.",
      "severity": "ERROR",
      "scope": { "@id": "genesis-planet" }
    },
    {
      "type": "Constraint",
      "id": "katra-transfer-requirement",
      "name": "Katra must be reunited",
      "description": "Spock's katra in McCoy's mind must be brought to Vulcan and reunited with Spock's body via fal-tor-pan, or both McCoy and Spock's essence will be lost.",
