  "constraints": [
    {
      "type": "Constraint",
      "id": "temporal-existence-dependency",
      "name": "A person cannot exist in a time period where their birth has been prevented",
      "description": "If a time traveller's actions in the past prevent their own birth, they progressively cease to exist. Any character whose causal chain of existence is broken cannot persist in any time period.",
      "severity": "ERROR"
    },
    {
      "type": "Constraint",
      "id": "flux-capacitor-threshold",
      "name": "Time travel requires 1.21 gigawatts and 88 mph",
      "description": "The DeLorean can only traverse time when it reaches 88 mph and the flux capacitor is powered by exactly 1.21 gigawatts. Without both conditions met simultaneously, time travel does not occur.",
      "severity": "ERROR",
      "scope": {
        "selectorType": "node",
        "selectorItem": "delorean"
      }
    }
  ]
