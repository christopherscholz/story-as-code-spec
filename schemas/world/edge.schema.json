{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "A relationship between two nodes that persists over time.",
  "required": [
    "id",
    "type",
    "name",
    "source",
    "target"
  ],
  "properties": {
    "id": {
      "type": "string",
      "examples": [
        "hero-in-village",
        "hero-loves-companion"
      ]
    },
    "type": {
      "type": "string",
      "examples": [
        "SPATIAL",
        "KINSHIP",
        "CONFLICT",
        "RELATIONSHIP",
        "KNOWLEDGE"
      ]
    },
    "name": {
      "type": "string",
      "description": "Verb describing the relationship",
      "examples": [
        "mentors",
        "owns",
        "borders",
        "loves",
        "located-in"
      ]
    },
    "description": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "directed": {
      "type": "boolean",
      "default": true,
      "description": "Whether the edge is directed (source → target). Default true."
    },
    "scope": {
      "$ref": "../common/expression.schema.json",
      "description": "Temporal scope of this edge. Omit for edges that always hold. Valid selectors: time_system, time, frame."
    },
    "properties": {
      "type": "object",
      "description": "Additional attributes as key-value pairs"
    },
    "weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "description": "Relationship strength"
    }
  },
  "examples": [
    {
      "id": "cave-adjacent-lighthouse",
      "type": "SPATIAL",
      "name": "adjacent-to",
      "source": "hidden-cave",
      "target": "lighthouse",
      "directed": false
    },
    {
      "id": "hero-in-dungeon",
      "type": "SPATIAL",
      "name": "located-in",
      "source": "hero",
      "target": "dungeon",
      "scope": {
        "range": [
          { "type": "time", "item": "T10" },
          { "type": "time", "item": "T15" }
        ]
      }
    },
    {
      "id": "hero-has-sword",
      "type": "SPATIAL",
      "name": "possesses",
      "source": "hero",
      "target": "magic-sword",
      "scope": {
        "and": [
          { "type": "frame", "item": "alt-timeline" },
          {
            "range": [
              { "type": "time", "item": "T5" },
              null
            ]
          }
        ]
      }
    }
  ]
}
