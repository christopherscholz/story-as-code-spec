{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "A relationship between two nodes that persists over time.",
  "required": [
    "id",
    "type",
    "name",
    "source",
    "target"
  ],
  "properties": {
    "id": {
      "type": "string",
      "examples": [
        "hero-in-village",
        "hero-loves-companion"
      ]
    },
    "type": {
      "type": "string",
      "examples": [
        "SPATIAL",
        "KINSHIP",
        "CONFLICT",
        "RELATIONSHIP",
        "KNOWLEDGE"
      ]
    },
    "name": {
      "type": "string",
      "description": "Verb describing the relationship",
      "examples": [
        "mentors",
        "owns",
        "borders",
        "loves",
        "located-in"
      ]
    },
    "description": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "directed": {
      "type": "boolean",
      "default": true,
      "description": "Whether the edge is directed (source → target). Default true."
    },
    "valid_in": {
      "type": "array",
      "description": "When and where this edge exists. Omit for edges that always hold.",
      "items": {
        "type": "object",
        "properties": {
          "frame": {
            "type": "string",
            "description": "Frame ID — omit for all frames"
          },
          "from": {
            "type": "string",
            "description": "Start of the time span — omit for unbounded start"
          },
          "to": {
            "type": "string",
            "description": "End of the time span — omit for unbounded end"
          }
        }
      }
    },
    "properties": {
      "type": "object",
      "description": "Additional attributes as key-value pairs"
    },
    "weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "description": "Relationship strength"
    }
  },
  "examples": [
    {
      "id": "cave-adjacent-lighthouse",
      "type": "SPATIAL",
      "name": "adjacent-to",
      "source": "hidden-cave",
      "target": "lighthouse",
      "directed": false
    },
    {
      "id": "hero-in-dungeon",
      "type": "SPATIAL",
      "name": "located-in",
      "source": "hero",
      "target": "dungeon",
      "valid_in": [
        {
          "from": "T10",
          "to": "T15"
        }
      ]
    },
    {
      "id": "hero-has-sword",
      "type": "SPATIAL",
      "name": "possesses",
      "source": "hero",
      "target": "magic-sword",
      "valid_in": [
        {
          "frame": "alt-timeline",
          "from": "T5"
        }
      ]
    }
  ]
}
