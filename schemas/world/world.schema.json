{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "The world graph — ground truth of the story universe.",
  "not": {
    "required": ["$ref"]
  },
  "properties": {
    "time_system": {
      "$ref": "time-system.schema.json"
    },
    "nodes": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "../common/ref.schema.json"
          },
          {
            "$ref": "node.schema.json"
          }
        ]
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "../common/ref.schema.json"
          },
          {
            "$ref": "edge.schema.json"
          }
        ]
      }
    },
    "frames": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "../common/ref.schema.json"
          },
          {
            "$ref": "frame.schema.json"
          }
        ]
      },
      "description": "Alternative timelines and branches"
    },
    "constraints": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "../common/ref.schema.json"
          },
          {
            "$ref": "constraint.schema.json"
          }
        ]
      }
    }
  },
  "examples": [
    {
      "time_system": {
        "id": "earth-time",
        "type": "LINEAR"
      },
      "nodes": [
        {
          "id": "hero",
          "type": "CHARACTER"
        }
      ],
      "edges": [
        {
          "id": "hero-in-village",
          "type": "SPATIAL",
          "name": "located-in",
          "source": "hero",
          "target": "village"
        }
      ]
    }
  ]
}
