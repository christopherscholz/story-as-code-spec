{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "A story beat — selects world elements and adds dramaturgical structure.",
  "required": [
    "id",
    "name"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "parent": {
      "type": "string",
      "description": "Parent beat ID"
    },
    "node_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "World node IDs relevant to this beat"
    },
    "edge_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "World edge IDs relevant to this beat"
    },
    "function": {
      "type": "string",
      "enum": [
        "HOOK",
        "INCITING_INCIDENT",
        "RISING_ACTION",
        "FIRST_THRESHOLD",
        "PINCH_POINT",
        "MIDPOINT",
        "CRISIS",
        "CLIMAX",
        "RESOLUTION",
        "DENOUEMENT",
        "CUSTOM"
      ],
      "description": "Dramaturgical function"
    },
    "reveals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "target"
        ],
        "properties": {
          "target": {
            "type": "string",
            "description": "Node or edge ID being revealed"
          },
          "degree": {
            "type": "string",
            "enum": [
              "HINT",
              "PARTIAL",
              "FULL"
            ],
            "default": "FULL",
            "description": "How much is disclosed"
          }
        }
      },
      "description": "Information disclosed to the reader at this beat"
    },
    "tension": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Tension level at this beat (for tension curve modeling)"
    },
    "emotional_target": {
      "type": "number",
      "minimum": -1.0,
      "maximum": 1.0,
      "description": "Target emotional valence at this beat"
    },
    "transition": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "CUT",
            "FADE",
            "CLIFFHANGER",
            "TIME_SKIP",
            "CONTINUATION"
          ],
          "description": "How this beat connects to the next"
        },
        "to_beat": {
          "type": "string",
          "description": "Beat ID this transitions to (if cross-hierarchy)"
        }
      }
    }
  },
  "examples": [
    {
      "id": "main-storyline",
      "name": "The Hero's Journey"
    },
    {
      "id": "the-call",
      "name": "The Call to Adventure",
      "parent": "main-storyline",
      "node_ids": [
        "hero",
        "mentor"
      ],
      "edge_ids": [
        "hero-meets-mentor"
      ],
      "function": "INCITING_INCIDENT",
      "tension": 0.4,
      "reveals": [
        {
          "target": "mentor",
          "degree": "PARTIAL"
        }
      ],
      "transition": {
        "type": "CLIFFHANGER"
      }
    }
  ]
}
