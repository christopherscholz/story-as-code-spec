{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "A world rule that validates the world graph.",
  "required": [
    "id",
    "name",
    "rule",
    "severity"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "rule": {
      "type": "string",
      "description": "The rule to enforce, expressed in story-world terms"
    },
    "severity": {
      "type": "string",
      "enum": [
        "ERROR",
        "WARNING",
        "INFO"
      ],
      "description": "ERROR — must resolve. WARNING — flags issue. INFO — suggestion only."
    },
    "scope": {
      "type": "object",
      "description": "What this rule applies to. Omit for global rules.",
      "properties": {
        "node_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "edge_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nodes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "frames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "time_range": {
          "type": "object",
          "properties": {
            "from": {
              "type": "string"
            },
            "to": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "examples": [
    {
      "id": "no-isolated-characters",
      "name": "Every character knows at least one other character",
      "rule": "Every character must have at least one relationship with another character.",
      "severity": "WARNING",
      "scope": {
        "node_types": [
          "CHARACTER"
        ]
      }
    },
    {
      "id": "magic-limit",
      "name": "Magic users can hold at most 3 spells",
      "rule": "No person may hold more than three spells at any given time.",
      "severity": "ERROR"
    },
    {
      "id": "no-undead-before-war",
      "name": "Undead cannot exist before the Great War",
      "rule": "The undead do not exist in the world before the Great War.",
      "severity": "ERROR",
      "scope": {
        "node_types": [
          "CHARACTER"
        ],
        "time_range": {
          "to": "T50"
        }
      }
    }
  ]
}
