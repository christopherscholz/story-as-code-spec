{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "Reusable tag and type definitions. Optional — elements may use tags and types without a matching definition.",
  "properties": {
    "tags": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "ref.schema.json"
          },
          {
            "$ref": "tag.schema.json"
          }
        ]
      }
    },
    "types": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "ref.schema.json"
          },
          {
            "$ref": "type.schema.json"
          }
        ]
      }
    }
  },
  "examples": [
    {
      "tags": [
        {
          "id": "protagonist",
          "name": "Protagonist",
          "description": "The central character driving the story."
        }
      ],
      "types": [
        {
          "id": "CHARACTER",
          "name": "Character",
          "applies_to": "NODE"
        }
      ]
    }
  ]
}
