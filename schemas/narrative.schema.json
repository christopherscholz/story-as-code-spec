{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "The narrative layer — how the world is told.",
  "properties": {
    "lenses": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "ref.schema.json"
          },
          {
            "$ref": "lens.schema.json"
          }
        ]
      },
      "description": "Narrative perspectives"
    },
    "formats": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "ref.schema.json"
          },
          {
            "$ref": "format.schema.json"
          }
        ]
      },
      "description": "Output format definitions"
    },
    "beats": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "ref.schema.json"
          },
          {
            "$ref": "beat.schema.json"
          }
        ]
      },
      "description": "Hierarchical narrative building blocks"
    },
    "devices": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "ref.schema.json"
          },
          {
            "$ref": "device.schema.json"
          }
        ]
      },
      "description": "Rhetorical techniques connecting beats (foreshadowing, red herrings, etc.)"
    },
    "threads": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "ref.schema.json"
          },
          {
            "$ref": "thread.schema.json"
          }
        ]
      },
      "description": "Thematic threads and motifs connecting beats across storylines"
    },
    "variants": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "ref.schema.json"
          },
          {
            "$ref": "variant-meta.schema.json"
          }
        ]
      },
      "description": "Parallel world version metadata"
    }
  }
}
