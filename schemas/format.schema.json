{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "Output format definition — the structural container for content.",
  "required": [
    "id",
    "name",
    "type",
    "structure"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "description": "Output medium (e.g. NOVEL, SCREENPLAY, COMIC)",
      "examples": [
        "NOVEL",
        "SCREENPLAY",
        "COMIC",
        "AUDIO",
        "INTERACTIVE"
      ]
    },
    "name": {
      "type": "string"
    },
    "structure": {
      "$ref": "#/$defs/Structure"
    },
    "settings": {
      "type": "object",
      "description": "Type-specific settings as free-form key-value pairs"
    }
  },
  "examples": [
    {
      "id": "novel-format",
      "type": "NOVEL",
      "name": "Standard Novel",
      "structure": {
        "type": "book",
        "children": {
          "type": "chapter",
          "constraints": {
            "word_count_min": 3000,
            "word_count_max": 8000
          },
          "children": {
            "type": "scene"
          }
        }
      }
    },
    {
      "id": "comic-format",
      "type": "COMIC",
      "name": "Comic Issue",
      "structure": {
        "type": "issue",
        "children": {
          "type": "page",
          "constraints": {
            "panel_count_max": 9
          },
          "children": {
            "type": "panel"
          }
        }
      }
    }
  ],
  "$defs": {
    "Structure": {
      "type": "object",
      "description": "Recursive structural level (e.g. book → chapter → scene).",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "description": "Level identifier (e.g. book, chapter, scene, page, panel)",
          "examples": [
            "book",
            "chapter",
            "scene",
            "page",
            "panel",
            "segment"
          ]
        },
        "constraints": {
          "type": "object",
          "description": "Constraints for this level (e.g. word count, panel count)"
        },
        "children": {
          "$ref": "#/$defs/Structure"
        }
      }
    }
  }
}
