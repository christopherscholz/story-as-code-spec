{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "Root document of a Story as Code project. Composes world (the ground truth — what exists) and narrative (the storytelling perspective — how it is told). The narrative layer never defines its own truth; it only selects, filters, and presents world layer content. The spec does not prescribe a directory layout — file organization is a tooling concern.\n",
  "required": [
    "spec_version",
    "name",
    "world"
  ],
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the Story as Code spec this story conforms to",
      "examples": [
        "0.5.0"
      ]
    },
    "name": {
      "type": "string",
      "description": "Human-readable name of the story",
      "examples": [
        "My Story",
        "An Epic Saga"
      ]
    },
    "settings": {
      "type": "object",
      "properties": {
        "default_language": {
          "type": "string",
          "description": "ISO 639-1 language code",
          "examples": [
            "en",
            "de"
          ]
        }
      }
    },
    "definitions": {
      "oneOf": [
        {
          "$ref": "ref.schema.json"
        },
        {
          "$ref": "definitions.schema.json"
        }
      ]
    },
    "world": {
      "oneOf": [
        {
          "$ref": "ref.schema.json"
        },
        {
          "$ref": "world.schema.json"
        }
      ]
    },
    "narrative": {
      "oneOf": [
        {
          "$ref": "ref.schema.json"
        },
        {
          "$ref": "narrative.schema.json"
        }
      ]
    }
  },
  "examples": [
    {
      "spec_version": "0.5.0",
      "name": "My Story",
      "definitions": {
        "tags": [
          {
            "id": "protagonist",
            "name": "Protagonist"
          }
        ],
        "types": [
          {
            "id": "CHARACTER",
            "name": "Character",
            "applies_to": "NODE"
          },
          {
            "id": "SPATIAL",
            "name": "Spatial Relationship",
            "applies_to": "EDGE"
          }
        ]
      },
      "world": {
        "time_system": {
          "id": "earth-time",
          "type": "LINEAR"
        },
        "nodes": [
          {
            "id": "hero",
            "type": "CHARACTER"
          }
        ],
        "edges": [
          {
            "id": "hero-in-village",
            "type": "SPATIAL",
            "name": "located-in",
            "source": "hero",
            "target": "village"
          }
        ]
      },
      "narrative": {
        "lenses": [
          {
            "id": "omniscient",
            "perspective": {
              "type": "OMNISCIENT"
            }
          }
        ],
        "beats": [
          {
            "id": "main-storyline",
            "name": "The Hero's Journey"
          }
        ]
      }
    }
  ]
}
