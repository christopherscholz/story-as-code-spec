{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "A narrative perspective — who tells the story, what they know, and how reliable they are.",
  "required": [
    "id",
    "perspective"
  ],
  "properties": {
    "id": {
      "type": "string",
      "examples": [
        "hero-pov",
        "omniscient",
        "unreliable-narrator"
      ]
    },
    "type": {
      "type": "string",
      "enum": [
        "SIMPLE",
        "COMPOSITE"
      ],
      "default": "SIMPLE"
    },
    "perspective": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "CHARACTER_BOUND",
            "OMNISCIENT",
            "OBJECTIVE",
            "CUSTOM"
          ]
        },
        "anchor": {
          "type": "string",
          "description": "Node ID — for CHARACTER_BOUND"
        },
        "person": {
          "type": "string",
          "enum": [
            "FIRST",
            "SECOND",
            "THIRD"
          ]
        }
      }
    },
    "knowledge": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "OMNISCIENT",
            "CHARACTER_KNOWLEDGE",
            "PUBLIC_ONLY"
          ]
        },
        "include_subconscious": {
          "type": "boolean",
          "default": false
        },
        "include_wrong_beliefs": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "temporal_position": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "IN_MOMENT",
            "RETROSPECTIVE",
            "PROPHETIC"
          ]
        },
        "narrating_from": {
          "type": "string",
          "description": "Time point from which the narrator looks back"
        },
        "knows_future_until": {
          "type": "string"
        }
      }
    },
    "emotional": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "NEUTRAL",
            "CHARACTER_STATE",
            "CUSTOM"
          ]
        },
        "bias": {
          "type": "object",
          "properties": {
            "toward": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "bias_strength": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            }
          }
        }
      }
    },
    "voice": {
      "type": "object",
      "properties": {
        "vocabulary_level": {
          "type": "string",
          "enum": [
            "LITERARY",
            "FORMAL",
            "COLLOQUIAL",
            "ARCHAIC",
            "MINIMAL"
          ]
        },
        "sentence_tendency": {
          "type": "string",
          "enum": [
            "FLOWING",
            "SHORT_STACCATO",
            "COMPLEX_NESTED"
          ]
        },
        "inner_monologue": {
          "type": "boolean",
          "default": true
        },
        "metaphor_density": {
          "type": "string",
          "enum": [
            "NONE",
            "LOW",
            "MEDIUM",
            "HIGH"
          ]
        },
        "verbal_tics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "language_rendering": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "NATURALISTIC",
                "TRANSLATED_WITH_MARKERS",
                "INLINE_CONSTRUCTED",
                "FULL_CONLANG"
              ]
            }
          }
        }
      }
    },
    "reliability": {
      "type": "object",
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "RELIABLE",
            "SELECTIVE",
            "UNRELIABLE",
            "LYING"
          ]
        },
        "omits": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Event IDs this narrator skips or downplays"
        },
        "distorts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "node": {
                "type": "string"
              },
              "direction": {
                "type": "string",
                "enum": [
                  "POSITIVE",
                  "NEGATIVE"
                ]
              }
            }
          }
        }
      }
    },
    "layers": {
      "type": "array",
      "description": "For COMPOSITE: layered lens configuration",
      "items": {
        "type": "object",
        "required": [
          "lens",
          "role"
        ],
        "properties": {
          "lens": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "BASE",
              "DIP",
              "OVERRIDE"
            ]
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "description": "Higher value takes priority on conflict"
          },
          "trigger": {
            "type": "object",
            "properties": {
              "when": {
                "type": "string"
              },
              "node": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "alternation": {
      "type": "object",
      "description": "For COMPOSITE: alternation configuration",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "PER_SCENE",
            "PER_CHAPTER",
            "FLUID"
          ]
        },
        "sequence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "trigger": {
          "type": "string",
          "enum": [
            "SCENE_BREAK",
            "POV_TAG",
            "TIME_SHIFT"
          ]
        }
      }
    },
    "composition": {
      "type": "object",
      "description": "For COMPOSITE: conflict resolution between sub-lenses",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "LAYERED",
            "ALTERNATING",
            "BLENDED"
          ]
        },
        "conflict_resolution": {
          "type": "object",
          "properties": {
            "knowledge": {
              "type": "string",
              "enum": [
                "UNION",
                "INTERSECTION",
                "PRIORITY_WINS"
              ],
              "default": "PRIORITY_WINS",
              "description": "UNION — knows everything any sub-lens knows. INTERSECTION — only shared knowledge. PRIORITY_WINS — higher priority decides."
            },
            "emotion": {
              "type": "string",
              "enum": [
                "BLEND",
                "PRIORITY_WINS",
                "DOMINANT"
              ],
              "default": "BLEND",
              "description": "BLEND — averaged. PRIORITY_WINS — higher priority decides. DOMINANT — strongest emotion wins."
            },
            "voice": {
              "type": "string",
              "enum": [
                "PRIORITY_WINS",
                "ALTERNATING"
              ],
              "default": "PRIORITY_WINS",
              "description": "PRIORITY_WINS — higher priority decides. ALTERNATING — switches with active sub-lens."
            },
            "reliability": {
              "type": "string",
              "enum": [
                "LEAST_RELIABLE",
                "MOST_RELIABLE",
                "PRIORITY_WINS"
              ],
              "default": "PRIORITY_WINS",
              "description": "LEAST_RELIABLE — inherits least reliable. MOST_RELIABLE — inherits most reliable. PRIORITY_WINS — higher priority decides."
            }
          }
        }
      }
    }
  },
  "examples": [
    {
      "id": "hero-pov",
      "perspective": {
        "type": "CHARACTER_BOUND",
        "anchor": "hero",
        "person": "FIRST"
      },
      "knowledge": {
        "mode": "CHARACTER_KNOWLEDGE"
      },
      "voice": {
        "vocabulary_level": "COLLOQUIAL",
        "sentence_tendency": "SHORT_STACCATO"
      },
      "reliability": {
        "level": "SELECTIVE",
        "omits": [
          "secret-meeting"
        ]
      }
    },
    {
      "id": "omniscient",
      "perspective": {
        "type": "OMNISCIENT",
        "person": "THIRD"
      },
      "knowledge": {
        "mode": "OMNISCIENT"
      },
      "voice": {
        "vocabulary_level": "LITERARY",
        "metaphor_density": "HIGH"
      }
    }
  ]
}
