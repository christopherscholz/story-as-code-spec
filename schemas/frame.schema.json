{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "An alternative timeline or branch. Frames form a graph via parent references and relations.",
  "required": [
    "id",
    "name"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "parent": {
      "type": "string",
      "description": "Frame this one branched from"
    },
    "branches_at": {
      "type": "string",
      "description": "Time point where this frame diverges from parent"
    },
    "relations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/FrameRelation"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "properties": {
      "type": "object",
      "description": "Additional metadata as key-value pairs"
    }
  },
  "examples": [
    {
      "id": "main",
      "name": "Main Timeline"
    },
    {
      "id": "alt-timeline",
      "name": "What if the hero refused?",
      "parent": "main",
      "branches_at": "T42",
      "relations": [
        {
          "target": "main",
          "type": "BRANCHES_INTO",
          "at": "T42",
          "description": "Hero refuses the call"
        }
      ]
    },
    {
      "id": "time-loop",
      "name": "Groundhog Day Loop",
      "parent": "main",
      "relations": [
        {
          "target": "main",
          "type": "LOOPS_BACK",
          "at": "T100"
        }
      ],
      "properties": {
        "loop_count": 3,
        "observer": "char-hero"
      }
    }
  ],
  "$defs": {
    "FrameRelation": {
      "type": "object",
      "required": [
        "target",
        "type"
      ],
      "properties": {
        "target": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "description": "Relation type (e.g. BRANCHES_INTO, MERGES_WITH, LOOPS_BACK)"
        },
        "at": {
          "type": "string",
          "description": "Time point"
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
