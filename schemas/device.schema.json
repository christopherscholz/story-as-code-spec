{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "A narrative device — a rhetorical technique connecting beats.",
  "required": [
    "id",
    "type",
    "setup"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "FORESHADOWING",
        "RED_HERRING",
        "SETUP_PAYOFF",
        "DRAMATIC_IRONY",
        "ECHO",
        "CONTRAST",
        "PARALLEL",
        "CALLBACK",
        "CHEKHOV_GUN",
        "CUSTOM"
      ]
    },
    "description": {
      "type": "string"
    },
    "setup": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Beat IDs where the device is planted"
    },
    "payoff": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Beat IDs where it resolves"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "examples": [
    {
      "id": "journal-setup-payoff",
      "type": "SETUP_PAYOFF",
      "description": "The journal found in the cave pays off when used to confront Elara.",
      "setup": [
        "cave-found"
      ],
      "payoff": [
        "truth-revealed"
      ]
    },
    {
      "id": "elara-red-herring",
      "type": "RED_HERRING",
      "description": "Elara's mysterious behavior suggests danger but is actually protectiveness.",
      "setup": [
        "stranger-arrives"
      ],
      "payoff": [
        "truth-revealed"
      ]
    }
  ]
}
