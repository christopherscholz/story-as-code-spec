{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "Metadata for a parallel world version — canon, speculative, retcon, fork, or collaboration.",
  "required": [
    "type"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "CANON",
        "SPECULATIVE",
        "RETCON",
        "FORK",
        "COLLAB"
      ]
    },
    "parent_variant": {
      "type": "string",
      "description": "Variant this one diverged from"
    },
    "description": {
      "type": "string"
    },
    "affects_frames": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "merge_strategy": {
      "type": "string",
      "enum": [
        "PICK_A",
        "PICK_B",
        "FORK_FRAME",
        "MANUAL"
      ]
    }
  },
  "examples": [
    {
      "type": "CANON",
      "description": "The primary accepted version of events"
    },
    {
      "type": "SPECULATIVE",
      "description": "What if the hero had refused the call?",
      "parent_variant": "canon",
      "affects_frames": [
        "alt-timeline"
      ],
      "merge_strategy": "FORK_FRAME"
    }
  ]
}
