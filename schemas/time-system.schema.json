{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "How time works in this world — its structure and calendar.",
  "required": [
    "id",
    "name"
  ],
  "properties": {
    "id": {
      "type": "string",
      "examples": [
        "linear",
        "earth-calendar",
        "dreamworld"
      ]
    },
    "name": {
      "type": "string",
      "examples": [
        "Galactic Calendar",
        "Earth Time",
        "Dream Sequence"
      ]
    },
    "type": {
      "type": "string",
      "enum": [
        "LINEAR",
        "ABSTRACT"
      ],
      "description": "LINEAR — time points have a natural order and sort lexicographically. ABSTRACT — time points are unordered labels; sequence is defined through the graph."
    },
    "calendar": {
      "type": "object",
      "description": "Calendar structure"
    },
    "properties": {
      "type": "object",
      "description": "Additional time properties"
    }
  },
  "examples": [
    {
      "id": "linear",
      "name": "Linear Timeline",
      "type": "LINEAR"
    },
    {
      "id": "iso-8601",
      "name": "Gregorian Calendar",
      "type": "LINEAR"
    },
    {
      "id": "dreamworld",
      "name": "Dreamworld",
      "type": "ABSTRACT",
      "properties": {
        "note": "Time has no direction here; connections define sequence"
      }
    }
  ]
}
